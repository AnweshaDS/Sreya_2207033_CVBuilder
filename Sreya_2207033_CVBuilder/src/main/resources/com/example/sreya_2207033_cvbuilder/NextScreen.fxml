<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fx:id="scrollPane" fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sreya_2207033_cvbuilder.NextScreenController">

    <VBox alignment="TOP_CENTER" spacing="16" style="-fx-background-color: #1a1a2e;">
        <padding>
            <Insets bottom="24" left="24" right="24" top="24" />
        </padding>

        <!-- Top Bar -->
        <HBox alignment="CENTER_LEFT" maxWidth="980" spacing="14" style="-fx-background-color: #16213e; -fx-background-radius: 10; -fx-padding: 12 14 12 14;">
            <Button fx:id="backBtn" onAction="#handleBack" text="← Back"
                    style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 6 18 6 18;" />
            <Label text="Create Your CV" textFill="#FFF8DC">
                <font>
                    <Font name="Arial Bold" size="24" />
                </font>
            </Label>
        </HBox>

        <!-- Main Form Container -->
        <VBox maxWidth="980" spacing="14" style="-fx-background-color: #16213e; -fx-background-radius: 14; -fx-border-color: #0f3460; -fx-border-radius: 14;">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- TITLE + PHOTO ROW -->
            <HBox alignment="CENTER_LEFT" spacing="30">
                <Label text="Enter Your Personal Information" textFill="#E6EAF2">
                    <font>
                        <Font name="Arial Bold" size="27" />
                    </font>
                </Label>

                <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #1a1a2e; -fx-background-radius: 10; -fx-padding: 12;">
                    <ImageView fx:id="profileImageView" fitHeight="120" fitWidth="120" preserveRatio="true" style="-fx-border-color: #0f3460; -fx-border-width: 2;" />

                    <Button onAction="#handleUploadPhoto" style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-font-size: 13px;" text="Upload Photo" />
                </VBox>

            </HBox>

            <!-- Full Name -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="120" style="-fx-text-fill: #DCE3F0; -fx-font-weight: bold;" text="Full Name" />
                <TextField fx:id="fullNameField" prefWidth="760" style="-fx-background-color: #1a1a2e; -fx-text-fill: #E6EAF2; -fx-prompt-text-fill: #90A0B8;" />
            </HBox>

            <!-- Email -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="120" style="-fx-text-fill: #DCE3F0; -fx-font-weight: bold;" text="Email" />
                <TextField fx:id="emailField" prefWidth="760" style="-fx-background-color: #1a1a2e; -fx-text-fill: #E6EAF2; -fx-prompt-text-fill: #90A0B8;" />
            </HBox>

            <!-- Phone -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="120" style="-fx-text-fill: #DCE3F0; -fx-font-weight: bold;" text="Phone" />
                <TextField fx:id="phoneField" prefWidth="760" style="-fx-background-color: #1a1a2e; -fx-text-fill: #E6EAF2; -fx-prompt-text-fill: #90A0B8;" />
            </HBox>

            <!-- Address -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="120" style="-fx-text-fill: #DCE3F0; -fx-font-weight: bold;" text="Address" />
                <TextField fx:id="addressField" prefWidth="760" style="-fx-background-color: #1a1a2e; -fx-text-fill: #E6EAF2; -fx-prompt-text-fill: #90A0B8;" />
            </HBox>

            <!-- Education -->
            <Label style="-fx-text-fill: #FFF8DC;" text="Education">
                <font>
                    <Font name="Arial Bold" size="16.0" />
                </font>
            </Label>

            <!-- Education Table -->
            <VBox spacing="10">

                <!-- Table Header -->
                <HBox spacing="10">
                    <Label prefWidth="200" style="-fx-background-color: #0f3460; -fx-text-fill: #E6EAF2; -fx-padding: 6;" text="Degree" />
                    <Label prefWidth="250" style="-fx-background-color: #0f3460; -fx-text-fill: #E6EAF2; -fx-padding: 6;" text="Institute" />
                    <Label prefWidth="120" style="-fx-background-color: #0f3460; -fx-text-fill: #E6EAF2; -fx-padding: 6;" text="CGPA/GPA" />
                    <Label prefWidth="100" style="-fx-background-color: #0f3460; -fx-text-fill: #E6EAF2; -fx-padding: 6;" text="Year" />
                </HBox>

                <!-- List of Education Rows (dynamic) -->
                <VBox fx:id="educationList" spacing="8" />

                <!-- Add Entry Button -->
                <Button onAction="#handleAddEducation" prefWidth="170" style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-font-size: 14px;" text="Add Education" />
            </VBox>

            <!-- Skills -->
            <Label style="-fx-text-fill: #FFF8DC;" text="Skills">
                <font>
                    <Font name="Arial Bold" size="16.0" />
                </font>
            </Label>
            <TextArea fx:id="skillsField" editable="true" focusTraversable="true" prefHeight="110" style="-fx-control-inner-background: #1a1a2e; -fx-text-fill: #E6EAF2; -fx-prompt-text-fill: #90A0B8; -fx-highlight-fill: #0f3460; -fx-highlight-text-fill: white; -fx-background-insets: 0; -fx-background-radius: 6;" wrapText="true" />

            <!-- Experience -->
            <Label style="-fx-text-fill: #FFF8DC;" text="Experience">
                <font>
                    <Font name="Arial Bold" size="16.0" />
                </font>
            </Label>
            <TextArea fx:id="experienceField" editable="true" focusTraversable="true" prefHeight="130" style="-fx-control-inner-background: #1a1a2e; -fx-text-fill: #E6EAF2; -fx-prompt-text-fill: #90A0B8; -fx-highlight-fill: #0f3460; -fx-highlight-text-fill: white; -fx-background-insets: 0; -fx-background-radius: 6;" wrapText="true" />

            <!-- Projects -->
            <Label style="-fx-text-fill: #FFF8DC;" text="Projects">
            <opaqueInsets>
               <Insets />
            </opaqueInsets>
            <font>
               <Font name="Arial Bold" size="16.0" />
            </font></Label>
                <TextArea fx:id="projectsField" editable="true" focusTraversable="true" prefHeight="130" style="-fx-control-inner-background: #1a1a2e; -fx-text-fill: #E6EAF2; -fx-prompt-text-fill: #90A0B8; -fx-highlight-fill: #0f3460; -fx-highlight-text-fill: white; -fx-background-insets: 0; -fx-background-radius: 6;" wrapText="true" />

            <!-- Action Buttons -->
            <HBox alignment="CENTER" spacing="14">
                <Button onAction="#handleGenerateCV" prefWidth="210" style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-background-color: #e94560; -fx-text-fill: white;" text="Generate CV" />
                <Button onAction="#handleSeeRecords" prefWidth="190" style="-fx-font-size: 15px; -fx-background-color: #0f3460; -fx-text-fill: white;" text="See the Records" />
                <Button onAction="#handleExit" prefWidth="120" style="-fx-font-size: 15px; -fx-background-color: #8B0000; -fx-text-fill: white;" text="Exit" />
            </HBox>

        </VBox>
    </VBox>

</ScrollPane>
