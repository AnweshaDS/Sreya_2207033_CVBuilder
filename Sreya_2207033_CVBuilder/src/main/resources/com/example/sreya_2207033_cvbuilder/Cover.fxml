<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.sreya_2207033_cvbuilder.CoverController"
      style="-fx-background-color: #1a1a2e;">

    <!-- Header -->
    <HBox alignment="CENTER" style="-fx-background-color: #16213e; -fx-padding: 16 20 16 20;">
        <Label alignment="CENTER" maxWidth="Infinity" text="Welcome To CVBuilder" textFill="#FFF8DC">
            <font>
                <Font name="Arial Bold" size="34.0" />
            </font>
        </Label>
    </HBox>

    <!-- Main card -->
    <VBox alignment="CENTER" spacing="26" VBox.vgrow="ALWAYS" style="-fx-padding: 30;">
        <VBox alignment="CENTER" maxWidth="760" spacing="22"
              style="-fx-background-color: #16213e; -fx-background-radius: 16; -fx-border-color: #0f3460; -fx-border-radius: 16; -fx-padding: 34 34 30 34;">
            <Label alignment="CENTER" text="Build Your Professional CV in Minutes" textFill="#E6EAF2" wrapText="true">
                <font>
                    <Font name="Arial Bold" size="30.0" />
                </font>
            </Label>

            <Label alignment="CENTER" text="Fast, clean, and easy-to-use CV workflow" textFill="#A8B4C8">
                <font>
                    <Font size="18.0" />
                </font>
            </Label>

            <Button fx:id="createNewCvBtn" mnemonicParsing="false" onAction="#handleCreateNewCv"
                    style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-background-color: #e94560; -fx-text-fill: white; -fx-padding: 10 30 10 30;"
                    text="Create New CV">
                <font>
                    <Font size="18.0" />
                </font>
            </Button>

            <HBox alignment="CENTER" spacing="16">
                <Button mnemonicParsing="false" onAction="#handleSeeRecords"
                        style="-fx-font-size: 15px; -fx-background-color: #0f3460; -fx-text-fill: white; -fx-padding: 9 20 9 20;"
                        text="See the Records" />
                <Button mnemonicParsing="false" onAction="#handleExit"
                        style="-fx-font-size: 15px; -fx-background-color: #8B0000; -fx-text-fill: white; -fx-padding: 9 20 9 20;"
                        text="Exit" />
            </HBox>

            <padding>
                <Insets bottom="4" top="4" />
            </padding>
        </VBox>
    </VBox>

</VBox>
